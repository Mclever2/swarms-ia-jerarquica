# ── Clave OpenAI ───────────────────────────────────────────────────────────────
# Obtén tu clave en https://platform.openai.com/api-keys
# El sistema usa el modelo gpt-4o-mini (bajo costo, ~$0.01 USD por consulta)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx

# ── Parámetros del pipeline ────────────────────────────────────────────────────
MAX_ITERACIONES=3        # Ciclos máximos de mejora que el Director puede ejecutar
MAX_RONDAS_DEBATE=2      # (Legacy) rondas de debate — no afecta la jerarquía actual
SLEEP_BETWEEN_AGENTS=1   # Pausa entre agentes en segundos (1s es suficiente con OpenAI)

# ── Modelos (opcional — por defecto usa gpt-4o-mini) ──────────────────────────
# DIRECTOR_MODEL=gpt-4o-mini
# WORKER_MODEL=gpt-4o-mini

# ── Logging ────────────────────────────────────────────────────────────────────
LITELLM_LOG=ERROR        # Silencia logs de litellm (reduce ruido en consola)
SWARMS_VERBOSE=false     # Silencia logs internos de swarms
