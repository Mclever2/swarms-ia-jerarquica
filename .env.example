# ── Claves Groq ────────────────────────────────────────────────────────────────
# Obtén tu clave gratuita en https://console.groq.com
#
# Opción A: una clave única para todos los agentes (más simple)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx
#
# Opción B: clave diferente por agente (recomendado para evitar rate limits 429)
# Registra hasta 6 cuentas Groq y asigna una clave a cada agente.
GROQ_KEY_DIRECTOR=gsk_xxxxxxxxxxxxxxxxxxxx
GROQ_KEY_AUDITOR=gsk_xxxxxxxxxxxxxxxxxxxx
GROQ_KEY_METODOLOGICO=gsk_xxxxxxxxxxxxxxxxxxxx
GROQ_KEY_REDACTOR=gsk_xxxxxxxxxxxxxxxxxxxx
GROQ_KEY_CONSENSO=gsk_xxxxxxxxxxxxxxxxxxxx   # Herramienta opcional de análisis de acuerdos
GROQ_KEY_DISENSO=gsk_xxxxxxxxxxxxxxxxxxxx    # Herramienta opcional de análisis de conflictos

# ── Parámetros del pipeline ────────────────────────────────────────────────────
MAX_ITERACIONES=3        # Ciclos máximos de mejora que el Director puede ejecutar
MAX_RONDAS_DEBATE=2      # (Legacy) rondas de debate — no afecta la jerarquía actual

# ── Logging ────────────────────────────────────────────────────────────────────
LITELLM_LOG=ERROR        # Silencia logs de litellm (reduce ruido en consola)
SWARMS_VERBOSE=false     # Silencia logs internos de swarms
